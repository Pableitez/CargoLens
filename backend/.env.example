PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# API rate limit (optional; defaults: 400 requests / 15 min per IP)
# RATE_LIMIT_MAX=400
# RATE_LIMIT_WINDOW_MS=900000

# MongoDB (required for accounts & saved containers)
# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/freightboard
# Atlas (mismo cluster, otra DB: /cargolens o /freightboard — sin barra antes de ?):
# MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.xxxxx.mongodb.net/cargolens?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb://127.0.0.1:27017/freightboard
# Optional pool cap (default 10, max 50) when scaling API replicas against one cluster
# MONGODB_MAX_POOL_SIZE=20
# Demo user + containers: npm run seed:demo (see scripts/seed-demo-user.js)

# JWT signing (set a long random string in production)
JWT_SECRET=

# Optional — Safecube / Sinay (header API_KEY). Container Tracking and Ports & Vessels may be separate products—enable both in the Sinay / Developers portal if vessel search returns 401/403.
# SAFECUBE_API_KEY=
# Dashboard overview map: how many saved containers to enrich (default 12, max 24). Lower = faster response.
# SAFECUBE_OVERVIEW_MAX_CONTAINERS=12
# Parallel shipment fetches (default 6, max 12). Lower if the operator API returns 429.
# SAFECUBE_OVERVIEW_CONCURRENCY=6
# Ports & Vessels API v1 (vessel search) — default matches official Sinay swagger:
# SAFECUBE_VESSEL_BASE=https://api.sinay.ai/ports-vessels/api/v1

# Vessels Intelligence — optional AIS position enrichment after search (requires product on key; see Sinay Hub vessel API)
# SAFECUBE_VESSEL_INTEL_ENRICH=true
# SAFECUBE_VESSEL_INTEL_BASE=https://api.sinay.ai/vessels-intelligence/api/v1
# SAFECUBE_VESSEL_INTEL_POSITION_PATH=/vessel-position

# AISHub (optional) — last AIS position by MMSI when Sinay has no coordinates (join aishub.net, max ~1 req/min)
# AISHUB_USERNAME=your_aishub_username
# AISHUB_ENRICH=false
 
