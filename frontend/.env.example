# Producción (obligatoria en build de Cloudflare Pages / Vercel): URL absoluta del API, sin barra final.
# Debe terminar en /api porque Express monta las rutas bajo /api.
# En local puedes omitirla: Vite hace proxy de /api → http://localhost:4000
#
# VITE_API_BASE_URL=https://cargolens.onrender.com/api

# Canonical site URL for Open Graph (no trailing slash). Falls back to window.location.origin.
# VITE_SITE_URL=https://your-domain.com

# Product name and copy (optional; defaults in frontend/src/config/siteMeta.js)
# VITE_APP_NAME=CargoLens
# VITE_APP_TAGLINE=Container tracking
# VITE_APP_TITLE_SUFFIX=Seguimiento de contenedores
# VITE_APP_DESCRIPTION=

# Footer name / role (optional; defaults in frontend/src/config/siteMeta.js)
# VITE_SITE_AUTHOR_NAME=Pablo Benéitez
# VITE_SITE_AUTHOR_ROLE=
# VITE_SITE_AUTHOR_YEAR=2026
